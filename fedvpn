#!/bin/bash
# fedvpn — WireGuard VPN client
# First time:  fedvpn → 1 (setup)
# After that:  fedvpn → 2 (connect) / 3 (disconnect)

set -e

GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

WG_CONF="/etc/wireguard/wg0.conf"

vpn_setup() {
    echo ""

    # Install WireGuard if missing
    if ! command -v wg &>/dev/null; then
        echo -e "  Installing WireGuard..."
        if command -v dnf &>/dev/null; then
            sudo dnf install -y wireguard-tools
        elif command -v apt-get &>/dev/null; then
            sudo apt-get install -y wireguard
        elif command -v brew &>/dev/null; then
            brew install wireguard-tools
        else
            echo -e "  ${RED}Can't detect package manager. Install wireguard-tools manually.${NC}"
            return 1
        fi
        echo -e "  ${GREEN}WireGuard installed.${NC}"
    else
        echo -e "  ${GREEN}WireGuard installed.${NC}"
    fi

    echo ""

    # Check if config already exists
    if sudo test -f "$WG_CONF"; then
        echo -e "  ${YELLOW}Config already exists.${NC}"
        read -p "  Overwrite? [y/N] " -n 1 -r
        echo ""
        if [[ ! $REPLY =~ ^[Yy]$ ]]; then
            return
        fi
    fi

    echo -e "  Paste the config from the server, then press ${BOLD}Ctrl+D${NC}:"
    echo ""

    local config=""
    config=$(cat)

    if [[ -z "$config" ]] || ! echo "$config" | grep -q "\[Interface\]"; then
        echo ""
        echo -e "  ${RED}Invalid config.${NC}"
        return 1
    fi

    sudo mkdir -p /etc/wireguard
    echo "$config" | sudo tee "$WG_CONF" > /dev/null
    sudo chmod 600 "$WG_CONF"

    echo ""
    echo -e "  ${GREEN}Config saved.${NC}"
    echo -e "  Run ${BOLD}fedvpn${NC} → ${BOLD}2${NC} to connect."
}

vpn_start() {
    if ! command -v wg &>/dev/null || ! sudo test -f "$WG_CONF"; then
        echo -e "  ${RED}Not set up. Run fedvpn → 1 first.${NC}"
        return 1
    fi
    if sudo wg show wg0 &>/dev/null 2>&1; then
        echo -e "  ${GREEN}Already connected.${NC}"
        return
    fi
    sudo wg-quick up wg0
    echo -e "  ${GREEN}Connected.${NC} All traffic routed through server."
}

vpn_stop() {
    if ! sudo wg show wg0 &>/dev/null 2>&1; then
        echo -e "  ${DIM}Not running.${NC}"
        return
    fi
    sudo wg-quick down wg0
    echo -e "  ${YELLOW}Disconnected.${NC}"
}

vpn_status() {
    if ! command -v wg &>/dev/null; then
        echo -e "  ${RED}Not installed.${NC}"
        return
    fi
    if sudo wg show wg0 &>/dev/null 2>&1; then
        echo -e "  ${GREEN}VPN: connected${NC}"
        echo ""
        sudo wg show wg0 | while IFS= read -r line; do
            echo "  $line"
        done
    else
        echo -e "  ${RED}VPN: disconnected${NC}"
    fi
}

show_menu() {
    echo ""
    echo -e "${BOLD}fedvpn — WireGuard VPN${NC}"
    echo ""
    if sudo test -f "$WG_CONF"; then
        if sudo wg show wg0 &>/dev/null 2>&1; then
            echo -e "  ${GREEN}connected${NC}"
        else
            echo -e "  ${DIM}disconnected${NC}"
        fi
    else
        echo -e "  ${YELLOW}not set up${NC}"
    fi
    echo ""
    echo -e "  ${BOLD}1)${NC} Setup"
    echo -e "  ${BOLD}2)${NC} Connect"
    echo -e "  ${BOLD}3)${NC} Disconnect"
    echo -e "  ${BOLD}4)${NC} Status"
    echo -e "  ${BOLD}0)${NC} Exit"
    echo ""
    read -p "  Choose: " choice
    case $choice in
        1|setup)    vpn_setup ;;
        2|start)    vpn_start ;;
        3|stop)     vpn_stop ;;
        4|status)   vpn_status ;;
        0|exit|q)   exit 0 ;;
        *)          echo -e "  ${RED}Invalid choice.${NC}" ;;
    esac
}

case "${1:-}" in
    setup)          vpn_setup ;;
    start|up)       vpn_start ;;
    stop|down)      vpn_stop ;;
    status)         vpn_status ;;
    -h|--help|help) echo "Usage: fedvpn [setup|start|stop|status]" ;;
    "")             show_menu ;;
    *)              echo "Usage: fedvpn [setup|start|stop|status]" ;;
esac
