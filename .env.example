# Immich
UPLOAD_LOCATION=/mnt/data/immich/upload
DB_DATA_LOCATION=/mnt/data/immich/postgres
# Pinned to Immich's major tag: Watchtower auto-applies every v3.x.y patch/minor,
# but a breaking major (v4+) is a deliberate one-line bump — majors can need an
# ordered database migration. Bump this when you choose to move majors.
IMMICH_VERSION=v3
# Leave this placeholder as-is and run `privcloud config` to auto-generate a
# strong password, or replace it with your own before first start. This exact
# value is recognised as a placeholder and gets regenerated — never run a real
# database on it.
DB_PASSWORD=changeme_use_a_real_password
DB_USERNAME=postgres
DB_DATABASE_NAME=immich

# Media
MEDIA_LOCATION=/mnt/data/media

# Navidrome
MUSIC_LOCATION=/mnt/data/media/My Music

# FileBrowser
DATA_ROOT=/mnt/data
