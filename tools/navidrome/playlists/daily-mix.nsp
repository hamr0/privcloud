{
  "name": "🎲 Daily Mix",
  "comment": "Loved or already-played tracks you haven't heard in the last week, reshuffled.",
  "all": [
    { "any": [
      { "is": { "loved": true } },
      { "gt": { "playCount": 0 } }
    ]},
    { "notInTheLast": { "lastPlayed": 7 } }
  ],
  "sort": "random",
  "limit": 50
}
