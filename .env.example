# Storage location for uploaded photos
# Point this to your external HDD mount point
UPLOAD_LOCATION=/media/your-external-hdd/immich-photos

# Database
DB_DATA_LOCATION=./data/postgres

# Immich version (pin to specific version for stability)
IMMICH_VERSION=release

# Database credentials
DB_PASSWORD=changeme_use_a_real_password
DB_USERNAME=postgres
DB_DATABASE_NAME=immich
