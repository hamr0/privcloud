#!/usr/bin/env bash
set -euo pipefail

# privcloud — self-hosted photo backup
# https://github.com/hamr0/privcloud

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENV_FILE="$SCRIPT_DIR/.env"
COMPOSE_FILE="$SCRIPT_DIR/docker-compose.yml"
# Single source of truth for the version is package.json. readlink -f resolves
# through symlinks (the installed `privcloud` is a symlink into the repo) so we
# read package.json next to the REAL script, not next to /usr/local/bin.
_pc_self="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || printf '%s' "${BASH_SOURCE[0]}")"
VERSION="$(sed -n 's/.*"version"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$(dirname "$_pc_self")/package.json" 2>/dev/null)"
VERSION="${VERSION:-0.9.2}"
unset _pc_self
ORIG_ARGS="$*"
# ---------------------------------------------------------------------------
# Docker group fix: re-exec under sg docker if needed (once only)
# ---------------------------------------------------------------------------

if [ "${PRIVCLOUD_SG_DONE:-}" != "1" ]; then
  if ! docker info &>/dev/null 2>&1; then
    if id -nG "$USER" 2>/dev/null | grep -qw docker; then
      export PRIVCLOUD_SG_DONE=1
      exec sg docker "$0 $*"
    fi
  fi
fi

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

red()    { printf "\033[31m%s\033[0m\n" "$1"; }
green()  { printf "\033[32m%s\033[0m\n" "$1"; }
yellow() { printf "\033[33m%s\033[0m\n" "$1"; }
bold()   { printf "\033[1m%s\033[0m\n" "$1"; }

get_os() {
  case "$(uname -s)" in
    Linux*)
      if grep -qi microsoft /proc/version 2>/dev/null; then
        echo "wsl"
      else
        echo "linux"
      fi
      ;;
    Darwin*) echo "mac" ;;
    *)       echo "unknown" ;;
  esac
}

get_ip() {
  case "$(get_os)" in
    mac) ipconfig getifaddr en0 2>/dev/null || echo "localhost" ;;
    *)   hostname -I 2>/dev/null | awk '{print $1}' || echo "localhost" ;;
  esac
}

needs_selinux() {
  [ "$(get_os)" = "linux" ] && command -v getenforce &>/dev/null && [ "$(getenforce 2>/dev/null)" = "Enforcing" ]
}

compose_cmd() {
  if docker compose version &>/dev/null; then
    echo "docker compose"
  elif docker-compose version &>/dev/null; then
    echo "docker-compose"
  else
    echo ""
  fi
}

run_compose() {
  local cc
  cc="$(compose_cmd)"
  if [ -z "$cc" ]; then
    red "Docker Compose not found."
    exit 1
  fi
  $cc -f "$COMPOSE_FILE" --env-file "$ENV_FILE" "$@"
}

env_get() {
  grep "^${1}=" "$ENV_FILE" 2>/dev/null | cut -d'=' -f2-
}

patch_selinux() {
  if needs_selinux; then
    sed -i.bak \
      -e 's|\(\${UPLOAD_LOCATION}:/usr/src/app/upload\)$|\1:Z|' \
      -e 's|\(\${DB_DATA_LOCATION}:/var/lib/postgresql/data\)$|\1:Z|' \
      "$COMPOSE_FILE" && rm -f "${COMPOSE_FILE}.bak"
  else
    sed -i.bak \
      -e 's|\(\${UPLOAD_LOCATION}:/usr/src/app/upload\):Z|\1|' \
      -e 's|\(\${DB_DATA_LOCATION}:/var/lib/postgresql/data\):Z|\1|' \
      "$COMPOSE_FILE" && rm -f "${COMPOSE_FILE}.bak"
  fi
}

fix_permissions() {
  local upload_loc db_loc
  upload_loc="$(env_get UPLOAD_LOCATION)"
  db_loc="$(env_get DB_DATA_LOCATION)"
  mkdir -p "$upload_loc" "$db_loc"
  # 700, not 777: the Immich containers run as root, so they read/write these
  # dirs regardless of owner — no reason to expose private photos or the
  # database to every local user. (Postgres also requires its data dir to be
  # 0700 and resets it on init, so 777 here was a misleading no-op anyway.)
  chmod 700 "$db_loc" 2>/dev/null || true
  chmod 700 "$upload_loc" 2>/dev/null || true
}

elevate() {
  if sudo -n true 2>/dev/null; then
    sudo "$@"
  elif command -v pkexec &>/dev/null; then
    pkexec "$@"
  else
    sudo "$@"
  fi
}

ensure_docker() {
  if docker info &>/dev/null; then
    return 0
  fi

  case "$(get_os)" in
    mac)
      yellow "Starting Docker Desktop..."
      open -a Docker
      local wait=0
      while ! docker info &>/dev/null && [ $wait -lt 30 ]; do
        sleep 1; wait=$((wait + 1))
      done
      ;;
    wsl)
      red "Start Docker Desktop for Windows, then try again."
      exit 1
      ;;
    linux)
      if ! systemctl is-active docker &>/dev/null; then
        yellow "Starting Docker..."
        elevate systemctl start docker
        sleep 2
      fi
      if ! docker info &>/dev/null; then
        if ! id -nG "$USER" | grep -qw docker; then
          yellow "Adding you to the docker group..."
          elevate usermod -aG docker "$USER"
        fi
        # Re-exec with sg to activate group
        export PRIVCLOUD_SG_DONE=1
        exec sg docker "$0 $ORIG_ARGS"
      fi
      ;;
  esac

  if docker info &>/dev/null; then
    green "Docker started."
    return 0
  fi

  red "Could not start Docker. Start it manually and try again."
  exit 1
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

cmd_install() {
  bold "privcloud install"
  echo ""

  # Install Docker if missing
  if ! command -v docker &>/dev/null; then
    yellow "Docker not found. Installing..."
    case "$(get_os)" in
      mac)
        if command -v brew &>/dev/null; then
          brew install --cask docker
        else
          red "Install Homebrew first: https://brew.sh"
          red "Then run: brew install --cask docker"
          exit 1
        fi
        ;;
      wsl)
        red "Install Docker Desktop for Windows with WSL backend:"
        red "https://docker.com/products/docker-desktop"
        exit 1
        ;;
      linux)
        if command -v dnf &>/dev/null; then
          elevate dnf install -y docker docker-compose
          elevate systemctl enable docker
        elif command -v apt-get &>/dev/null; then
          elevate apt-get update
          elevate apt-get install -y docker.io docker-compose
        elif command -v pacman &>/dev/null; then
          elevate pacman -S --noconfirm docker docker-compose
          elevate systemctl enable docker
        else
          red "Could not detect package manager. Install Docker manually."
          exit 1
        fi
        ;;
    esac
    if ! command -v docker &>/dev/null; then
      red "Docker installation failed."
      exit 1
    fi
    green "Docker installed."
  fi
  green "Docker: $(docker --version)"

  ensure_docker

  # Install Docker Compose if missing
  if [ -z "$(compose_cmd)" ]; then
    yellow "Docker Compose not found. Installing..."
    case "$(get_os)" in
      mac|wsl)
        red "Docker Desktop includes Compose. Make sure it's up to date."
        exit 1
        ;;
      linux)
        if command -v dnf &>/dev/null; then
          elevate dnf install -y docker-compose
        elif command -v apt-get &>/dev/null; then
          elevate apt-get install -y docker-compose
        elif command -v pacman &>/dev/null; then
          elevate pacman -S --noconfirm docker-compose
        else
          red "Could not detect package manager. Install docker-compose manually."
          exit 1
        fi
        ;;
    esac
    if [ -z "$(compose_cmd)" ]; then
      red "Docker Compose installation failed."
      exit 1
    fi
    green "Docker Compose installed."
  fi
  green "Docker Compose: found"

  if [ ! -f "$ENV_FILE" ]; then
    echo ""
    bold "First-time setup"
    echo ""
    cmd_config
  else
    green "Config: $(env_get UPLOAD_LOCATION)"
  fi

  patch_selinux
  fix_permissions

  if needs_selinux; then
    green "SELinux: patched"
  fi

  echo ""
  bold "Pulling images (first time takes a few minutes)..."
  run_compose pull
  echo ""
  green "Install complete. Run: privcloud start"
}

cmd_start() {
  if [ ! -f "$ENV_FILE" ]; then
    red "Not set up yet. Run: privcloud install"
    exit 1
  fi

  ensure_docker

  # Already running?
  if curl -s http://localhost:2283/api/server/ping 2>/dev/null | grep -q pong; then
    bold "privcloud start"
    echo ""
    green "Already running."
    echo ""
    local ip
    ip="$(get_ip)"
    bold "Web UI:      http://localhost:2283"
    bold "iPhone app:  http://${ip}:2283"
    return 0
  fi

  patch_selinux
  fix_permissions

  bold "privcloud start"
  echo ""
  run_compose up -d

  echo ""
  printf "Waiting for Immich"
  local attempts=0
  while [ $attempts -lt 30 ]; do
    if curl -s http://localhost:2283/api/server/ping 2>/dev/null | grep -q pong; then
      echo ""
      echo ""
      green "privcloud is running."
      echo ""
      local ip
      ip="$(get_ip)"
      bold "Web UI:      http://localhost:2283"
      bold "iPhone app:  http://${ip}:2283"
      echo ""
      echo "Both devices must be on the same WiFi."
      echo "Stop with: privcloud stop"
      return 0
    fi
    sleep 2
    attempts=$((attempts + 1))
    printf "."
  done
  echo ""
  yellow "Taking longer than expected. Run: privcloud status"
}

cmd_stop() {
  ensure_docker

  bold "privcloud stop"
  echo ""
  run_compose down

  # Stop Docker daemon if no other containers are running
  if [ "$(get_os)" = "linux" ]; then
    local other_containers
    other_containers="$(docker ps -q 2>/dev/null)"
    if [ -z "$other_containers" ]; then
      echo "No other containers running. Stopping Docker..."
      elevate systemctl stop docker docker.socket
      green "Docker stopped."
    fi
  fi

  green "Stopped. Your photos are safe on disk."
}

cmd_status() {
  bold "privcloud status"
  echo ""

  # --- System ---
  bold "System"
  echo "  OS:       $(get_os) ($(uname -s) $(uname -r))"
  if command -v getenforce &>/dev/null; then
    local se
    se="$(getenforce 2>/dev/null)"
    if [ "$se" = "Enforcing" ]; then
      if grep -q ':Z' "$COMPOSE_FILE" 2>/dev/null; then
        green "  SELinux:  Enforcing (patched)"
      else
        red "  SELinux:  Enforcing (NOT patched — run: privcloud install)"
      fi
    else
      echo "  SELinux:  $se"
    fi
  fi
  echo ""

  # --- Docker ---
  bold "Docker"
  if command -v docker &>/dev/null; then
    green "  Engine:   $(docker --version | sed 's/Docker version //')"
  else
    red "  Engine:   not installed"
  fi
  local cc
  cc="$(compose_cmd)"
  if [ -n "$cc" ]; then
    green "  Compose:  found"
  else
    red "  Compose:  not found"
  fi
  echo ""

  # --- Storage ---
  bold "Storage"
  local upload_loc db_loc
  upload_loc="$(env_get UPLOAD_LOCATION 2>/dev/null || echo "")"
  db_loc="$(env_get DB_DATA_LOCATION 2>/dev/null || echo "")"

  if [ -n "$upload_loc" ] && [ -d "$upload_loc" ]; then
    local usage avail
    usage="$(du -sh "$upload_loc" 2>/dev/null | awk '{print $1}')"
    avail="$(df -h "$upload_loc" 2>/dev/null | awk 'NR==2{print $4}')"
    green "  Photos:   $upload_loc ($usage used, $avail free)"
  elif [ -n "$upload_loc" ]; then
    red "  Photos:   $upload_loc (missing)"
  else
    red "  Photos:   not configured"
  fi

  if [ -n "$db_loc" ] && [ -d "$db_loc" ]; then
    green "  Database: $db_loc"
  elif [ -n "$db_loc" ]; then
    red "  Database: $db_loc (missing)"
  fi

  echo "  Version:  $(env_get IMMICH_VERSION 2>/dev/null || echo "not set")"
  echo "  Change:   privcloud config"
  echo ""

  # --- Containers ---
  bold "Containers"
  if [ -n "$cc" ]; then
    local has_containers=false
    while IFS= read -r line; do
      has_containers=true
      if echo "$line" | grep -q "(healthy)"; then
        green "  $line"
      elif echo "$line" | grep -q "NAME"; then
        echo "  $line"
      elif echo "$line" | grep -qi "exit\|restart\|unhealthy"; then
        red "  $line"
      else
        yellow "  $line"
      fi
    done < <(run_compose ps --format "table {{.Name}}\t{{.Status}}" 2>/dev/null)

    if ! $has_containers; then
      yellow "  No containers running."
      echo ""
      echo "  Run: privcloud start"
      return
    fi
  fi

  echo ""

  # --- Health check ---
  if curl -s http://localhost:2283/api/server/ping 2>/dev/null | grep -q pong; then
    green "  Immich is responding"
    echo ""
    local ip
    ip="$(get_ip)"
    bold "  Web UI:   http://localhost:2283"
    bold "  Network:  http://${ip}:2283"
  else
    red "  Immich is NOT responding on port 2283"
  fi

  # --- Recent errors ---
  echo ""
  bold "Recent errors"
  local errors_found=false

  for container in immich_server immich_postgres immich_machine_learning immich_redis; do
    if docker ps -a --format '{{.Names}}' 2>/dev/null | grep -q "^${container}$"; then
      local err_lines
      err_lines="$(docker logs "$container" --tail 50 2>&1 | grep -iE 'error|fatal|panic|failed|exception|denied' | tail -3)"
      if [ -n "$err_lines" ]; then
        errors_found=true
        red "  ── $container ──"
        echo "$err_lines" | while IFS= read -r eline; do
          echo "    $eline"
        done
      fi
    fi
  done

  if ! $errors_found; then
    green "  No recent errors."
  fi
}

cmd_config() {
  bold "privcloud config"
  echo ""

  local current_loc
  current_loc="$(env_get UPLOAD_LOCATION 2>/dev/null || echo "")"
  if [ -n "$current_loc" ]; then
    echo "Current photo storage: $current_loc"
  fi

  local default_loc="${current_loc:-$HOME/privcloud/photos}"
  printf "Photo storage path [%s]: " "$default_loc"
  read -r upload_loc
  upload_loc="${upload_loc:-$default_loc}"
  upload_loc="${upload_loc/#\~/$HOME}"

  if ! mkdir -p "$upload_loc" 2>/dev/null; then
    red "Cannot create directory: $upload_loc"
    exit 1
  fi

  local db_loc
  db_loc="$(dirname "$upload_loc")/postgres"
  mkdir -p "$db_loc"

  local db_pass
  db_pass="$(env_get DB_PASSWORD 2>/dev/null || echo "")"
  if [ -z "$db_pass" ] || [ "$db_pass" = "changeme_use_a_real_password" ]; then
    db_pass="privcloud_$(head -c 16 /dev/urandom | base64 | tr -dc 'a-zA-Z0-9' | head -c 16)"
  fi

  cat > "$ENV_FILE" << EOF
UPLOAD_LOCATION=${upload_loc}
DB_DATA_LOCATION=${db_loc}
IMMICH_VERSION=release
DB_PASSWORD=${db_pass}
DB_USERNAME=postgres
DB_DATABASE_NAME=immich
EOF
  # Holds the DB password — keep it readable only by the owner.
  chmod 600 "$ENV_FILE" 2>/dev/null || true

  green "Config saved."
  echo "  Photos:   $upload_loc"
  echo "  Database: $db_loc"
}

cmd_upload() {
  bold "Upload Photos to privcloud"
  echo ""

  # Check if privcloud is running
  if ! curl -s http://localhost:2283/api/server/ping 2>/dev/null | grep -q pong; then
    red "privcloud is not running. Start it first: privcloud start"
    return 1
  fi

  # Immich CLI runs as a one-shot Docker container — no Node.js/npm on the host,
  # and it reuses the Docker that already runs the stack. The image is the
  # official one, pulled once and cached.
  local cli_image="ghcr.io/immich-app/immich-cli:latest"
  if ! docker image inspect "$cli_image" &>/dev/null; then
    yellow "Fetching Immich CLI image (one-time)..."
    if ! docker pull "$cli_image"; then
      red "Failed to pull Immich CLI image: $cli_image"
      red "Check the server's internet connection and Docker, then retry."
      return 1
    fi
  fi
  green "Immich CLI: $(docker run --rm "$cli_image" --version 2>/dev/null)"
  echo ""

  # Get API key (3 attempts)
  local api_key attempts=0
  while [ $attempts -lt 3 ]; do
    printf "API key (from http://localhost:2283 → Account Settings → API Keys): "
    read -r api_key

    if [ -z "$api_key" ]; then
      red "No API key provided."
      attempts=$((attempts + 1))
      continue
    fi

    # Pass the key via stdin (-H @-) so it never appears in the process arg list
    # (visible to other local users via `ps`).
    if curl -sf -H @- http://localhost:2283/api/users/me <<<"x-api-key: $api_key" &>/dev/null; then
      break
    fi

    attempts=$((attempts + 1))
    if [ $attempts -lt 3 ]; then
      red "Invalid API key. Try again ($((3 - attempts)) attempts left)."
    else
      red "Invalid API key. Giving up."
      return 1
    fi
  done
  green "API key valid."
  echo ""

  # Get photo path
  local photo_path
  printf "Path to photos folder: "
  read -r photo_path
  photo_path="${photo_path/#\~/$HOME}"
  # Strip quotes the user may have pasted
  photo_path="${photo_path//\'/}"
  photo_path="${photo_path//\"/}"

  if [ -z "$photo_path" ] || [ ! -d "$photo_path" ]; then
    red "Not a valid directory: $photo_path"
    return 1
  fi

  # Albums vs flat. --album makes the Immich CLI create one album per source
  # subfolder (named after the folder); flat just adds everything to the
  # timeline. Default (Enter / anything but 1) is flat.
  local album_flag=""
  echo ""
  echo "  How should the folders under this path be imported?"
  echo "    1) Albums  — one album per subfolder (keeps your folder names)"
  echo "    2) Flat    — everything into the timeline, no albums"
  printf "  Choose [1/2]: "
  read -r album_choice
  if [ "$album_choice" = "1" ]; then
    album_flag="--album"
    green "Albums: one per folder."
  else
    green "Flat import (no albums)."
  fi

  local file_count
  file_count="$(find "$photo_path" -type f \( -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.png' -o -iname '*.heic' -o -iname '*.heif' -o -iname '*.gif' -o -iname '*.mp4' -o -iname '*.mov' -o -iname '*.avi' \) | wc -l)"
  echo ""
  bold "Ready to upload $file_count media files from:"
  echo "  $photo_path"
  echo ""
  printf "Continue? [Y/n]: "
  read -r confirm
  if [[ "$confirm" =~ ^[Nn] ]]; then
    yellow "Cancelled."
    return 0
  fi

  echo ""
  # Mount the photos read-only at /import and upload from there. --network host
  # lets the CLI reach Immich on localhost:2283; label=disable avoids SELinux
  # relabeling the user's photo folder. Allocate a TTY only when we have one.
  local tflag=""
  [ -t 1 ] && tflag="-t"
  # Pass the key by NAME (-e IMMICH_API_KEY), inheriting its value from the
  # environment, so the secret is never on the `docker run` argv (which `ps`
  # would expose to other local users).
  IMMICH_API_KEY="$api_key" docker run --rm $tflag \
    --security-opt label=disable \
    --network host \
    -e IMMICH_INSTANCE_URL="http://localhost:2283/api" \
    -e IMMICH_API_KEY \
    -v "$photo_path":/import:ro \
    "$cli_image" upload --recursive $album_flag /import

  echo ""
  green "Upload complete. Browse your photos at http://localhost:2283"
}

cmd_backup() {
  while true; do
    bold "Backup privcloud"
    echo ""
    echo "  1) One time   — copy photos + database to a drive now"
    echo "  2) Scheduled  — recurring automatic backup (systemd timer, no downtime)"
    echo "  0) Back"
    echo ""
    printf "Choose [0-2]: "
    read -r btype
    case "$btype" in
      1)        cmd_backup_once ;;
      2)        cmd_backup_schedule ;;
      0|""|q)   return 0 ;;
      *)        red "Invalid choice." ;;
    esac
    echo ""
  done
}

# Scheduled-backup management. Delegates to setup.sh's step_immich_backup_menu —
# the SAME submenu federver → 14 → 6 uses — so set up / status / run / remove are
# single-source and both menus drive one schedule.
cmd_backup_schedule() {
  local setup="$SCRIPT_DIR/setup.sh"
  if [ ! -f "$setup" ]; then
    red "setup.sh not found next to privcloud ($setup)."
    red "Scheduled backups are configured by federver's setup.sh."
    return 1
  fi
  # Returns 2 on "Back" — don't let that abort privcloud under set -e.
  bash "$setup" --run step_immich_backup_menu || true
}

cmd_backup_once() {
  echo ""

  local upload_loc db_loc
  upload_loc="$(env_get UPLOAD_LOCATION)"
  db_loc="$(env_get DB_DATA_LOCATION)"

  if [ -z "$upload_loc" ] || [ -z "$db_loc" ]; then
    red "Not configured yet. Run: privcloud install"
    return 1
  fi

  # What to back up
  echo "What to back up:"
  echo "  1) Both — photos + database (default)"
  echo "  2) Photos only"
  echo "  3) Database only"
  echo "  0) Back"
  echo ""
  printf "Choose [0-3] (default: 1): "
  read -r scope
  local do_photos=true do_db=true
  case "$scope" in
    2)        do_db=false ;;
    3)        do_photos=false ;;
    1|"")     ;;
    0|q)      return 0 ;;
    *)        red "Invalid choice."; return 1 ;;
  esac

  # Show what we're backing up (size only what we'll copy)
  local photos_size="-" db_size="-"
  $do_photos && photos_size="$(sudo du -sh --block-size=1G "$upload_loc" 2>/dev/null | awk '{print $1" GB"}' || echo "unknown")"
  $do_db     && db_size="$(sudo du -sh --block-size=1M "$db_loc" 2>/dev/null | awk '{print $1" MB"}' || echo "unknown")"
  $do_photos && echo "  Photos:   $upload_loc ($photos_size)"
  $do_db     && echo "  Database: $db_loc ($db_size)"
  echo ""

  # Get destination
  local dest
  printf "Backup destination (e.g. /run/media/%s/External): " "$USER"
  read -r dest
  dest="${dest/#\~/$HOME}"
  dest="${dest//\'/}"
  dest="${dest//\"/}"
  dest="${dest%/}"

  if [ -z "$dest" ] || [ ! -d "$dest" ]; then
    red "Not a valid directory: $dest"
    return 1
  fi

  local backup_dir="$dest/privcloud-backup"
  local avail
  avail="$(df -h "$dest" 2>/dev/null | awk 'NR==2{print $4}')"
  echo ""
  echo "  Destination: $backup_dir/   (available on drive: $avail)"
  echo ""

  # No downtime: dump the live DB instead of stopping the stack. Detect whether
  # postgres is up — if so we dump online; if it's already down we cold-copy the
  # data dir (also safe). Either way the running state is left untouched.
  local pg_running=false
  if docker ps --format '{{.Names}}' 2>/dev/null | grep -qx immich_postgres; then
    pg_running=true
  fi

  printf "Start backup? [Y/n]: "
  read -r confirm
  if [[ "$confirm" =~ ^[Nn] ]]; then
    yellow "Cancelled."
    return 0
  fi

  # Photo sync mode (only relevant when copying photos)
  local rsync_delete=""
  if $do_photos; then
    echo ""
    echo "Photo sync mode:"
    echo "  1) Append — copy new/changed files, keep everything on backup (safe default)"
    echo "  2) Mirror — exact copy of source, removes files deleted from source"
    echo ""
    printf "Choose [1/2] (default: 1): "
    read -r sync_mode
    if [ "$sync_mode" = "2" ]; then
      rsync_delete="--delete"
      yellow "Mirror mode: files deleted from source will be removed from backup."
    fi
  fi

  echo ""
  mkdir -p "$backup_dir"

  # Photos — live rsync of write-once originals; safe while Immich runs.
  if $do_photos; then
    bold "Copying photos ($photos_size)..."
    if command -v rsync &>/dev/null; then
      if ! sudo rsync -a $rsync_delete --info=progress2 "$upload_loc/" "$backup_dir/photos/"; then
        red "Failed to copy photos (rsync error)."
        return 1
      fi
    else
      sudo cp -a "$upload_loc" "$backup_dir/photos"
    fi
    local photos_copied
    photos_copied="$(sudo du -sh "$backup_dir/photos" 2>/dev/null | awk '{print $1}')"
    green "Photos copied ($photos_copied)."
  fi

  # Database — no downtime. Online pg_dump when running; cold data-dir copy when
  # already stopped. db_method records which, so the restore hint matches.
  local db_method=""
  if $do_db; then
    if $pg_running; then
      bold "Dumping database (online, no downtime)..."
      local ts dump
      ts="$(date +%Y%m%d-%H%M)"
      dump="$backup_dir/immich-db-$ts.sql.gz"
      if docker exec immich_postgres pg_dumpall -U postgres | gzip > "$dump"; then
        chmod 600 "$dump" 2>/dev/null || true
        db_method="dump"
        green "Database dumped ($(du -sh "$dump" 2>/dev/null | awk '{print $1}')) → $(basename "$dump")"
      else
        rm -f "$dump"   # don't leave a partial/empty dump that looks valid
        red "Database dump failed. Is Immich healthy? Try: privcloud status"
        return 1
      fi
    else
      yellow "Immich is stopped — copying the database files directly (safe while down)."
      # Defense-in-depth: never cold-copy a live data dir (would be corrupt).
      if run_compose ps --quiet 2>/dev/null | grep -q .; then
        red "Some containers are still running — cannot safely cold-copy the database."
        red "Start Immich fully for an online dump, or './privcloud stop' first."
        return 1
      fi
      if command -v rsync &>/dev/null; then
        if ! sudo rsync -a $rsync_delete --info=progress2 "$db_loc/" "$backup_dir/postgres/"; then
          red "Failed to copy database (rsync error)."
          return 1
        fi
      else
        sudo cp -a "$db_loc" "$backup_dir/postgres"
      fi
      local db_copied
      db_copied="$(sudo du -sh "$backup_dir/postgres" 2>/dev/null | awk '{print $1}')"
      if [ "$db_copied" = "0" ] || [ "$db_copied" = "4.0K" ]; then
        red "Database backup appears empty ($db_copied)."
        return 1
      fi
      # Make backup readable without root (postgres files are owned by container user)
      sudo chown -R "$(id -u):$(id -g)" "$backup_dir/postgres"
      sudo chmod -R u+rw "$backup_dir/postgres"
      db_method="datadir"
      green "Database copied ($db_copied)."
    fi
  fi

  # Copy .env so restore knows the password and config. It holds the DB
  # password, so keep the backup copy readable only by the owner.
  if cp "$ENV_FILE" "$backup_dir/.env" 2>/dev/null; then
    chmod 600 "$backup_dir/.env" 2>/dev/null || true
  fi

  echo ""
  green "Backup complete!"
  echo "  Location: $backup_dir"
  $do_photos && echo "  Photos:   $backup_dir/photos"
  if [ "$db_method" = "dump" ]; then
    echo "  Database: $backup_dir/immich-db-*.sql.gz (SQL dump)"
  elif [ "$db_method" = "datadir" ]; then
    echo "  Database: $backup_dir/postgres (data dir)"
  fi
  echo "  Config:   $backup_dir/.env"
  echo ""
  echo "To restore on any machine:"
  echo "  1. Clone privcloud and run ./privcloud install"
  $do_photos && echo "  2. Point config to the backed-up photos directory"
  if [ "$db_method" = "dump" ]; then
    echo "  3. Start privcloud, then load the dump:"
    echo "       gunzip -c immich-db-*.sql.gz | docker exec -i immich_postgres psql -U postgres"
  elif [ "$db_method" = "datadir" ]; then
    echo "  3. Copy postgres/ and .env back, then ./privcloud start"
  fi
}

cmd_update() {
  bold "privcloud update"
  echo ""

  ensure_docker

  # Snapshot current image IDs
  local before_server before_ml
  before_server="$(docker images -q ghcr.io/immich-app/immich-server:release 2>/dev/null || echo "")"
  before_ml="$(docker images -q ghcr.io/immich-app/immich-machine-learning:release 2>/dev/null || echo "")"

  echo "Checking for updates..."
  run_compose pull --quiet 2>/dev/null

  local after_server after_ml
  after_server="$(docker images -q ghcr.io/immich-app/immich-server:release 2>/dev/null || echo "")"
  after_ml="$(docker images -q ghcr.io/immich-app/immich-machine-learning:release 2>/dev/null || echo "")"

  if [ "$before_server" = "$after_server" ] && [ "$before_ml" = "$after_ml" ]; then
    green "Already up to date."
    return 0
  fi

  echo ""
  [ "$before_server" != "$after_server" ] && yellow "  Server:           $before_server → $after_server"
  [ "$before_ml" != "$after_ml" ]         && yellow "  Machine Learning: $before_ml → $after_ml"
  echo ""

  printf "Apply update? [Y/n]: "
  read -r confirm
  if [[ "$confirm" =~ ^[Nn] ]]; then
    yellow "Cancelled. New images are pulled but containers unchanged."
    return 0
  fi

  echo ""
  run_compose up -d

  echo ""
  green "Update applied. Pruning old images..."
  docker image prune -f 2>/dev/null | tail -1
  echo ""
  green "Done."
}

cmd_fix_gp() {
  bold "Google Photos Metadata Fix"
  echo ""
  echo "Restores dates and GPS coordinates that Google strips from Takeout exports."
  echo ""

  local input_path
  printf "Path to folder with takeout zips (or a single .zip): "
  read -r input_path
  input_path="${input_path/#\~/$HOME}"

  if [ -z "$input_path" ]; then
    red "No path provided."
    return 1
  fi

  if [ ! -e "$input_path" ]; then
    red "Not found: $input_path"
    return 1
  fi

  bash "$SCRIPT_DIR/scripts/google-takeout-fix.sh" "$input_path"
}

cmd_menu() {
  while true; do
    echo ""
    bold "            _            _                 _"
    bold "  _ __ _ __(_)_   _____ | | ___  _   _  __| |"
    bold " | '_ \\| '__| \\ \\ / / __|| |/ _ \\| | | |/ _\` |"
    bold " | |_) | |  | |\\ V / (__ | | (_) | |_| | (_| |"
    bold " | .__/|_|  |_| \\_/ \\___||_|\\___/ \\__,_|\\__,_|"
    bold " |_|"
    echo ""
    echo "  Your photos. Your storage. No cloud required."
    echo "  v${VERSION}"
    echo ""
    echo "  1) install   Check prerequisites, pull images, set up config"
    echo "  2) start     Start privcloud"
    echo "  3) stop      Stop privcloud"
    echo "  4) status    Show status and diagnostics"
    echo "  5) config    Change photo storage location"
    echo "  6) update    Check for updates and apply"
    echo "  7) upload    Upload photos to privcloud"
    echo "  8) fix-gp    Fix Google Photos metadata (Takeout export)"
    echo "  9) backup    Backup photos + database (one-time or scheduled)"
    echo "  0) exit"
    echo ""
    printf "Choose [0-9]: "
    read -r choice
    case "$choice" in
      1|install)  cmd_install ;;
      2|start)    cmd_start ;;
      3|stop)     cmd_stop ;;
      4|status)   cmd_status ;;
      5|config)   cmd_config ;;
      6|update)   cmd_update ;;
      7|upload)   cmd_upload ;;
      8|fix-gp)   cmd_fix_gp ;;
      9|backup)   cmd_backup ;;
      0|exit|q)   return 0 ;;
      *)          red "Invalid choice." ;;
    esac
  done
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

cd "$SCRIPT_DIR"

case "${1:-}" in
  install) cmd_install ;;
  start)   cmd_start ;;
  stop)    cmd_stop ;;
  status)  cmd_status ;;
  config)  cmd_config ;;
  update)  cmd_update ;;
  upload)  cmd_upload ;;
  fix-gp)  cmd_fix_gp ;;
  backup)  cmd_backup ;;
  --help|-h) cmd_menu ;;
  "")      cmd_menu ;;
  *)
    red "Unknown command: $1"
    cmd_menu
    exit 1
    ;;
esac
